{
    "model": {
        "type": "minecraft:condition",
        "property": "minecraft:crossbow/charged",
        "on_true": {
            "type": "minecraft:range_dispatch",
            "property": "minecraft:custom_model_data",
            "entries": [
                {
                    "threshold": 1,
                    "model": {
                        "type": "minecraft:model",
                        "model": "item/none"
                    }
                }
            ],
            "fallback": {
                "type": "minecraft:condition",
                "property": "minecraft:crossbow/firework",
                "on_true": {
                    "type": "minecraft:model",
                    "model": "item/crossbow_firework"
                },
                "on_false": {
                    "type": "minecraft:model",
                    "model": "item/crossbow_arrow"
                }
            }
        },
        "on_false": {
            "type": "minecraft:condition",
            "property": "minecraft:using_item",
            "on_true": {
                "type": "minecraft:range_dispatch",
                "property": "minecraft:crossbow/pull",
                "entries": [
                    {
                        "threshold": 1.0,
                        "model": {
                            "type": "minecraft:model",
                            "model": "item/crossbow_pulling_2"
                        }
                    },
                    {
                        "threshold": 0.58,
                        "model": {
                            "type": "minecraft:model",
                            "model": "item/crossbow_pulling_1"
                        }
                    }
                ],
                "fallback": {
                    "type": "minecraft:model",
                    "model": "item/crossbow_pulling_0"
                }
            },
            "on_false": {
                "type": "minecraft:model",
                "model": "item/crossbow_standby"
            }
        }
    }
}